{
  "name": "hono-atproto-relay",
  "description": "AT Protocol relay server",
  "options": {
    "port": {
      "type": "number",
      "description": "Port to listen on",
      "env": "PORT",
      "default": 2584
    },
    "hostname": {
      "type": "string",
      "description": "Relay hostname",
      "env": "HOSTNAME",
      "default": "127.0.0.1"
    },
    "local-dev-relay-port": {
      "type": "number",
      "description": "When set, patch fetch+WebSocket to route *.localhost through this dispatcher port"
    }
  }
}
